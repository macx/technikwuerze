{
  "name": "macx/technikwuerze",
  "description": "Website of the first ever podcast for developers in Germany",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "getkirby/cms": "^5.0",
    "arnoson/kirby-vite": "^4.0",
    "thathoff/kirby-git-content": "^5.4",
    "mauricerenck/podcaster": "^3.4",
    "mauricerenck/komments": "^3.7",
    "mzur/kirby-uniform": "^5.7",
    "arnoson/kirby-loupe": "^0.4",
    "arnoson/kirby-form-builder": "^0.9.1",
    "medienbaecker/kirby-help-view": "^1.2",
    "vlucas/phpdotenv": "^5.6"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  },
  "extra": {
    "kirby": {
      "install": true
    }
  },
  "require-dev": {
    "lukaskleinschmidt/kirby-types": "^1.1"
  }
}
