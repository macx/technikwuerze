{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Prepare Development Environment",
      "dependsOn": ["🖥️ PHP Server", "⚡ Vite Dev Server"],
      "dependsOrder": "parallel"
    },
    {
      "label": "🖥️ PHP Server",
      "type": "shell",
      "command": ". ./.env 2>/dev/null || true; [ -n \"$DEV_HOST\" ] || DEV_HOST=127.0.0.1; [ -n \"$DEV_PHP_PORT\" ] || DEV_PHP_PORT=8000; php -S \"$DEV_HOST:$DEV_PHP_PORT\" -t public kirby/router.php",
      "isBackground": true,
      "problemMatcher": {
        "owner": "php-server",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Development Server.*started"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "⚡ Vite Dev Server",
      "type": "shell",
      "command": ". ./.env 2>/dev/null || true; [ -n \"$DEV_HOST\" ] || DEV_HOST=127.0.0.1; [ -n \"$DEV_VITE_PORT\" ] || DEV_VITE_PORT=5173; [ -d .dev ] && rm -rf .dev || true; pnpm exec vite --host \"$DEV_HOST\" --port \"$DEV_VITE_PORT\"",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite-server",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "🏗️ Vite Build Watch",
      "type": "shell",
      "command": ". ./.env 2>/dev/null || true; VITE_WATCH=true pnpm exec vite build --watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite-build",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "built in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false,
        "close": true
      }
    },
    {
      "label": "Prepare Build-Dev Environment",
      "dependsOn": ["🖥️ PHP Server", "🏗️ Vite Build Watch"],
      "dependsOrder": "parallel"
    },
    {
      "label": "🛑 Stop Development Environment",
      "type": "shell",
      "command": ". ./.env 2>/dev/null || true; [ -n \"$DEV_HOST\" ] || DEV_HOST=127.0.0.1; [ -n \"$DEV_PHP_PORT\" ] || DEV_PHP_PORT=8000; pkill -INT -f \"php -S $DEV_HOST:$DEV_PHP_PORT\" 2>/dev/null || true; pkill -INT -f \"vite\" 2>/dev/null || true",
      "presentation": {
        "reveal": "never",
        "panel": "new",
        "close": true
      }
    },
    {
      "label": "Run script",
      "type": "shell",
      "command": "node check-git.js",
      "isBackground": false
    },
    {
      "label": "Run script cjs",
      "type": "shell",
      "command": "mv check-git.js check-git.cjs && node check-git.cjs",
      "isBackground": false
    },
    {
      "label": "Run script cjs",
      "type": "shell",
      "command": "node check-git.cjs",
      "isBackground": false
    },
    {
      "label": "Run js",
      "type": "shell",
      "command": "node check-git2.js",
      "isBackground": false
    },
    {
      "label": "Cleanup",
      "type": "shell",
      "command": "rm -f git-out.txt check-git2.js check-git.cjs check-git.js",
      "isBackground": false
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "pnpm run format",
      "isBackground": false
    }
  ]
}
