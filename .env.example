# Kirby Environment Configuration
# Copy this file to .env and adjust values for your environment

# Set the Kirby mode (local, staging, production)
# This determines which config file is loaded: site/config/config.{mode}.php
KIRBY_MODE=local

# Optional: Set debugging (overrides config.php setting)
# KIRBY_DEBUG=true

# Optional: Panel URL if different from default
# KIRBY_PANEL_URL=https://yourdomain.com/panel

# Optional: local development host/ports for VS Code tasks and Vite dev server
DEV_HOST=localhost
DEV_PHP_PORT=8000
DEV_VITE_PORT=5173

# Contact form mail settings
TW_MAIL_NOREPLY=no-reply@example.com
TW_CONTACT_RECIPIENT=kontakt@example.com
TW_SMTP_HOST=smtp.example.com
TW_SMTP_PORT=587
TW_SMTP_SECURITY=tls
TW_SMTP_USER=your-smtp-username
TW_SMTP_PASS=your-smtp-password

# Optional runtime sync config (for pnpm sync:* scripts)
# Uses SSH key auth; do not store passwords here.
# SYNC_HOST=p705890.webspaceconfig.de
# SYNC_USER=p705890
# SYNC_PORT=22
# SYNC_REMOTE_PROJECT_PATH=/html
